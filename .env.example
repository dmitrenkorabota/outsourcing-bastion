# Railway автоматически выдаёт этот URL когда подключаешь Postgres plugin
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Случайная строка >= 32 символов (генерируй сам, например: openssl rand -hex 32)
SESSION_SECRET="замени-на-случайную-строку-минимум-32-символа"

# Получить у @BotFather в Telegram
TELEGRAM_BOT_TOKEN="1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Юзернейм бота без @ (например: mybot_bot)
TELEGRAM_BOT_USERNAME="твой_бот_username"

# URL Railway-деплоя (выдаётся после первого деплоя, вида https://xxx.railway.app)
NEXT_PUBLIC_APP_URL="https://твой-проект.railway.app"
